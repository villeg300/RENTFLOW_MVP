############################################
# 1) INSCRIPTION + ACTIVATION
############################################

### Inscription
POST {{baseUrl}}/users/
Content-Type: application/json

{
  "phone_number": "{{phone}}",
  "full_name": "{{fullName}}",
  "email": "{{email}}",
  "password": "{{password}}",
  "re_password": "{{password}}"
}

### Activation du compte (uid + token depuis l'email)
POST {{baseUrl}}/users/activation/
Content-Type: application/json

{
  "uid": "{{uid}}",
  "token": "{{token}}"
}

############################################
# 2) LOGIN
############################################

### Connexion avec numero de telephone
POST {{baseUrl}}/jwt/create/
Content-Type: application/json

{
  "login": "{{phone}}",
  "password": "{{password}}"
}

### Connexion avec email
POST {{baseUrl}}/jwt/create/
Content-Type: application/json

{
  "login": "{{email}}",
  "password": "{{password}}",
  "agency_id": null
}

############################################
# 3) PROFIL / VERIFY / REFRESH / LOGOUT
############################################

### Profil courant (token requis)
GET {{baseUrl}}/users/me/
Authorization: Bearer {{accessToken}}

### Verifier access token
POST {{baseUrl}}/jwt/verify/
Content-Type: application/json

{
  "token": "{{accessToken}}"
}

### Refresh token (rotation active)
POST {{baseUrl}}/jwt/refresh/
Content-Type: application/json

{
  "refresh": "{{refreshToken}}"
}

### Logout (blacklist refresh)
POST {{baseUrl}}/jwt/logout/
Content-Type: application/json

{
  "refresh": "{{refreshToken}}"
}

### Logout global (tous les appareils)
POST {{baseUrl}}/jwt/logout_all/
Authorization: Bearer {{accessToken}}

############################################
# 4) CHANGEMENT DE MOT DE PASSE
############################################

### Changement de mot de passe (auth requis)
POST {{baseUrl}}/users/set_password/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "current_password": "{{password}}",
  "new_password": "{{newPassword}}"
}

### Connexion avec le nouveau mot de passe (email)
POST {{baseUrl}}/jwt/create/
Content-Type: application/json

{
  "login": "{{email}}",
  "password": "{{newPassword}}"
}

############################################
# 5) MOT DE PASSE OUBLIE
############################################

### Mot de passe oublie (envoi email)
POST {{baseUrl}}/users/reset_password/
Content-Type: application/json

{
  "email": "{{email}}"
}

### Confirmer reinitialisation (uid + token depuis l'email)
POST {{baseUrl}}/users/reset_password_confirm/
Content-Type: application/json

{
  "uid": "{{uid}}",
  "token": "{{token}}",
  "new_password": "{{resetPassword}}",
  "re_new_password": "{{resetPassword}}"
}

### Connexion apres reinitialisation (email)
POST {{baseUrl}}/jwt/create/
Content-Type: application/json

{
  "login": "{{email}}",
  "password": "{{resetPassword}}"
}

############################################
# NOTE
# - Avec ROTATE_REFRESH_TOKENS=True :
#   Le refresh token change apres chaque /jwt/refresh/.
#   Remplace {{refreshToken}} par le nouveau refresh.
############################################

############################################
# 6) AGENCES (MULTI-TENANT)
############################################

### Creer une agence
POST {{apiRoot}}/agencies/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Agence Alpha",
  "email": "villeg300@gmail.com",
  "phone_number": "74372878",
  "address": "Ouagadougou"
}

### Lister mes agences
GET {{apiRoot}}/agencies/
Authorization: Bearer {{accessToken}}

############################################
# 7) INVITATIONS D'EQUIPE
############################################

### Inviter un membre
POST {{apiRoot}}/agencies/{{agencyId}}/invitations/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "villeg300@gmail.com",
  "role": "agent",
  "message": "Bienvenue dans l'equipe."
}

### Relancer une invitation
POST {{apiRoot}}/agencies/{{agencyId}}/invitations/{{inviteId}}/resend/
Authorization: Bearer {{accessToken}}

### Revoquer une invitation
POST {{apiRoot}}/agencies/{{agencyId}}/invitations/{{inviteId}}/revoke/
Authorization: Bearer {{accessToken}}

### Voir une invitation (public)
GET {{apiRoot}}/agencies/invitations/{{inviteToken}}/

### Accepter l'invitation (auth requis)
POST {{apiRoot}}/agencies/invitations/accept/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "token": "{{inviteToken}}"
}

### Accepter l'invitation (sans compte: auto inscription)
POST {{apiRoot}}/agencies/invitations/accept/
Content-Type: application/json

{
  "token": "{{inviteToken}}",
  "full_name": "Nouvel Agent",
  "phone_number": "0700000099"
}


### Dashboard
GET {{apiRoot}}/dashboard/finance/
Authorization: Bearer {{accessToken}}
X-Agency-ID: {{agencyId}}


### Dashboard export
GET {{apiRoot}}/dashboard/finance/export/
Authorization: Bearer {{accessToken}}
X-Agency-ID: {{agencyId}}
